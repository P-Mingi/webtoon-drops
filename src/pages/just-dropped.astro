---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SeriesCard from '../components/SeriesCard.astro';
import seriesData from '../data/series-data.json';

// Determine which series dropped in the last 24 hours (KST)
function droppedInLast24h(series) {
  if (series.on_hiatus || series.update_day === null) return false;

  const KST_OFFSET_MS = 9 * 60 * 60 * 1000;
  const now = new Date();
  const nowKST = new Date(now.getTime() + KST_OFFSET_MS);
  const currentDayKST = nowKST.getUTCDay();
  const currentHourKST = nowKST.getUTCHours();
  const releaseHour = series.release_hour_kst ?? 0;

  // Same day check
  if (series.update_day === currentDayKST) {
    return currentHourKST >= releaseHour;
  }

  // Yesterday check — if the series drops on the day before today KST
  const yesterdayKST = (currentDayKST + 6) % 7;
  if (series.update_day === yesterdayKST) {
    const hoursElapsed = (24 - releaseHour) + currentHourKST;
    return hoursElapsed < 24;
  }

  return false;
}

// Also get series dropping in the next 3 hours — "dropping soon"
function droppingInNext3h(series) {
  if (series.on_hiatus || series.update_day === null) return false;

  const KST_OFFSET_MS = 9 * 60 * 60 * 1000;
  const now = new Date();
  const nowKST = new Date(now.getTime() + KST_OFFSET_MS);
  const currentDayKST = nowKST.getUTCDay();
  const currentHourKST = nowKST.getUTCHours();
  const currentMinKST = nowKST.getUTCMinutes();
  const releaseHour = series.release_hour_kst ?? 0;

  if (series.update_day !== currentDayKST) return false;
  const minutesUntil = (releaseHour * 60) - (currentHourKST * 60 + currentMinKST);
  return minutesUntil > 0 && minutesUntil <= 180;
}

const justDropped = seriesData
  .filter(droppedInLast24h)
  .sort((a, b) => (b.anilist_id || 0) - (a.anilist_id || 0));

const droppingSoon = seriesData
  .filter(droppingInNext3h)
  .sort((a, b) => {
    const KST_OFFSET_MS = 9 * 60 * 60 * 1000;
    const nowKST = new Date(new Date().getTime() + KST_OFFSET_MS);
    const minA = ((a.release_hour_kst ?? 0) * 60) - (nowKST.getUTCHours() * 60 + nowKST.getUTCMinutes());
    const minB = ((b.release_hour_kst ?? 0) * 60) - (nowKST.getUTCHours() * 60 + nowKST.getUTCMinutes());
    return minA - minB;
  });

// KST date string for the page
const KST_OFFSET_MS = 9 * 60 * 60 * 1000;
const todayKST = new Date(new Date().getTime() + KST_OFFSET_MS);
const todayLabel = todayKST.toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC'
});

const title = `New Manhwa Episodes Today — ${todayLabel} | WebtoonDrops`;
const description = `${justDropped.length} manhwa and webtoon episodes released in the last 24 hours. See what just dropped today on WEBTOON, Tapas, MangaPlus and Tappytoon.`;
---

<Base title={title} description={description} canonical="https://webtoondrops.com/just-dropped">
  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="logo">
        <span class="logo-drop">W</span>ebtoon<span class="logo-accent">Drops</span>
      </a>
      <nav class="header-nav">
        <a href="/just-dropped" class="nav-link active">Today</a>
        <a href="/this-week" class="nav-link">This Week</a>
        <a href="/genre" class="nav-link">Genres</a>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main class="just-dropped-page container">

    <header class="page-header">
      <h1>⚡ Just Dropped</h1>
      <p class="date-label">{todayLabel} (KST)</p>
      <p class="page-subtitle">
        Manhwa and webtoon episodes released in the last 24 hours.
      </p>
    </header>

    <!-- Dropping soon strip -->
    {droppingSoon.length > 0 && (
      <section class="dropping-soon-section">
        <h2>🔜 Dropping in the Next 3 Hours</h2>
        <div class="series-grid">
          {droppingSoon.map(s => <SeriesCard series={s} />)}
        </div>
      </section>
    )}

    <!-- Just dropped -->
    <section class="dropped-section">
      <h2>
        ✅ Released in the Last 24h
        <span class="count-badge">{justDropped.length}</span>
      </h2>

      {justDropped.length > 0 ? (
        <div class="series-grid">
          {justDropped.map(s => <SeriesCard series={s} />)}
        </div>
      ) : (
        <div class="empty-state">
          <p>No episodes have dropped in the last 24 hours.</p>
          <p>Check back tomorrow — or see <a href="/this-week">this week's full schedule</a>.</p>
        </div>
      )}
    </section>

    <!-- SEO content -->
    <section class="seo-content">
      <h2>Today's Manhwa & Webtoon Releases</h2>
      <p>
        This page shows every manhwa and webtoon that released a new episode in
        the last 24 hours, across all major platforms: WEBTOON, Tapas, MangaPlus,
        and Tappytoon. All times are based on Korean Standard Time (KST, UTC+9).
      </p>
      <p>
        Bookmark this page and check back daily to stay up to date with new episodes.
        You can also browse the <a href="/this-week">full weekly schedule</a> to plan
        ahead, or subscribe to notifications for individual series so you never miss a drop.
      </p>
    </section>

  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="/" class="back-link">← Back to all series</a>
      <span>WebtoonDrops — countdowns in KST (UTC+9)</span>
    </div>
  </footer>

  <script>
    import { startCountdowns } from '../scripts/countdown.js';
    document.addEventListener('DOMContentLoaded', startCountdowns);
  </script>
</Base>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    position: sticky; top: 0;
    background: var(--bg); z-index: 10;
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px; font-weight: 700; color: var(--text); letter-spacing: -0.3px;
    text-decoration: none;
  }
  .logo-drop { font-family: 'Orbitron', sans-serif; color: var(--accent); }
  .logo-accent { color: var(--accent); }

  .header-nav { display: flex; gap: 16px; flex: 1; justify-content: center; }
  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--muted); text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover, .nav-link.active { color: var(--accent); }

  .just-dropped-page { padding: 2rem 20px; }

  .page-header { text-align: center; margin-bottom: 2.5rem; }
  .page-header h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800; margin-bottom: 0.4rem;
    color: var(--text);
  }
  .date-label {
    color: var(--accent); font-weight: 600; font-size: 0.95rem;
    margin-bottom: 0.4rem;
    font-family: 'Space Grotesk', sans-serif;
  }
  .page-subtitle { color: var(--muted); font-size: 0.95rem; font-family: 'Inter', sans-serif; }

  .dropping-soon-section {
    margin-bottom: 3rem;
    padding: 1.5rem;
    background: rgba(108, 99, 255, 0.06);
    border: 1px solid rgba(108, 99, 255, 0.2);
    border-radius: 16px;
  }
  .dropping-soon-section h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem;
    color: var(--accent);
  }

  .dropped-section { margin-bottom: 3rem; }
  .dropped-section h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem; font-weight: 700;
    margin-bottom: 1rem; padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
    display: flex; align-items: center; gap: 10px;
    color: var(--text);
  }

  .count-badge {
    background: var(--accent);
    color: white;
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 13px;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .empty-state a { color: var(--accent); }

  .seo-content { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .seo-content h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem;
    color: var(--text);
  }
  .seo-content p {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin-bottom: 0.75rem;
  }
  .seo-content a { color: var(--accent); }

  .site-footer { border-top: 1px solid var(--border); padding: 24px 0; margin-top: 2rem; }
  .footer-inner {
    display: flex; flex-wrap: wrap; gap: 12px;
    justify-content: space-between;
    font-size: 12px; color: var(--muted);
    font-family: 'Space Grotesk', sans-serif;
  }
  .back-link { color: var(--accent); text-decoration: none; }
  .back-link:active { opacity: 0.75; }

  @media (max-width: 600px) {
    .series-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
  }
</style>
