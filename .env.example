# WebtoonDrops — environment variables
#
# Generate VAPID keys once:
#   npx web-push generate-vapid-keys
#
# Then add to Vercel dashboard (Settings → Environment Variables):
#   VAPID_PUBLIC_KEY   — also add as PUBLIC_VAPID_KEY for client-side access
#   VAPID_PRIVATE_KEY  — server-only, never expose
#   VAPID_SUBJECT      — e.g. mailto:hello@webtoondrops.com

# Exposed to the browser via import.meta.env.PUBLIC_VAPID_KEY
PUBLIC_VAPID_KEY=

# Server-side only
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@webtoondrops.com
