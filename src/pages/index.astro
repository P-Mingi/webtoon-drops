---
import Base from '../layouts/Base.astro';
import SeriesCard from '../components/SeriesCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import GenreFilter from '../components/GenreFilter.astro';
import seriesData from '../data/series-data.json';

function getNextDropDays(s) {
  if (s.on_hiatus || s.update_day == null) return Infinity;
  const nowKST = new Date(Date.now() + 9 * 60 * 60 * 1000);
  const currentDayKST = nowKST.getUTCDay();
  let daysAhead = (s.update_day - currentDayKST + 7) % 7;
  if (daysAhead === 0) daysAhead = 7;
  return daysAhead;
}

const series = [...seriesData].sort((a, b) => getNextDropDays(a) - getNextDropDays(b));

const genres = [...new Set(seriesData.map(s => s.genre))].sort();
const platforms = [
  { value: 'webtoon',   label: 'WEBTOON' },
  { value: 'tapas',     label: 'TAPAS' },
  { value: 'mangaplus', label: 'MANGA PLUS' },
  { value: 'tappytoon', label: 'TAPPYTOON' },
];
---

<Base>
  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="logo">
        <span class="logo-drop">W</span>ebtoon<span class="logo-accent">Drops</span>
      </a>
      <nav class="header-nav">
        <a href="/just-dropped" class="nav-link">Today</a>
        <a href="/this-week" class="nav-link">This Week</a>
        <a href="/genre" class="nav-link">Genres</a>
        <a href="/my-schedule" class="nav-link">My Schedule</a>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <h1>countdown to your<br /><span class="hero-accent">next episode drop</span></h1>
      <p class="hero-sub">Live release timers for every major WEBTOON, Tapas, and MANGA Plus series. No spoilers. Pure utility.</p>
    </section>

    <div class="search-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="series-search"
        type="search"
        placeholder="Search series…"
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <GenreFilter genres={genres} platforms={platforms} />

    <div class="day-filter-row">
      <div class="day-group">
        <button class="day-btn active" data-day-value="all">All Days</button>
        <button class="day-btn" data-day-value="today">Today</button>
        <button class="day-btn" data-day-value="1">Mon</button>
        <button class="day-btn" data-day-value="2">Tue</button>
        <button class="day-btn" data-day-value="3">Wed</button>
        <button class="day-btn" data-day-value="4">Thu</button>
        <button class="day-btn" data-day-value="5">Fri</button>
        <button class="day-btn" data-day-value="6">Sat</button>
        <button class="day-btn" data-day-value="0">Sun</button>
      </div>
      <button class="trending-btn" data-view="all" id="trending-toggle">🔥 Trending</button>
    </div>

    <div class="card-grid">
      {series.map(s => <SeriesCard series={s} />)}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>WebtoonDrops — all countdowns in KST (UTC+9)</span>
      <span>Not affiliated with WEBTOON, Tapas, or MANGA Plus</span>
    </div>
  </footer>

  <script>
    import { startCountdowns } from '../scripts/countdown.js';

    const KST_OFFSET_MS = 9 * 60 * 60 * 1000;

    function getNextDropMs(updateDay) {
      if (updateDay === null) return Infinity;
      const nowKST = new Date(Date.now() + KST_OFFSET_MS);
      const currentDayKST = nowKST.getUTCDay();
      let daysAhead = (updateDay - currentDayKST + 7) % 7;
      if (daysAhead === 0) daysAhead = 7;
      return daysAhead * 24 * 60 * 60 * 1000;
    }

    const KST_DAY_NOW = () => {
      const kst = new Date(Date.now() + 9 * 60 * 60 * 1000);
      return kst.getUTCDay();
    };

    function applyFilters() {
      const activePlatform = document.querySelector('[data-filter-type="platform"].active')?.dataset.filterValue ?? 'all';
      const activeGenre = document.querySelector('[data-filter-type="genre"].active')?.dataset.filterValue ?? 'all';
      const activeDay = document.querySelector('.day-btn.active')?.dataset.dayValue ?? 'all';
      const isTrending = document.getElementById('trending-toggle')?.dataset.view === 'trending';
      const query = (document.getElementById('series-search')?.value ?? '').toLowerCase().trim();

      const todayKST = KST_DAY_NOW();

      const allCards = [...document.querySelectorAll('.card')];

      // First pass: apply platform / genre / search / day filters
      const visible = allCards.filter(card => {
        const platforms = JSON.parse(card.dataset.platforms || '[]');
        const platformMatch = activePlatform === 'all' || platforms.includes(activePlatform);
        const genreMatch = activeGenre === 'all' || card.dataset.genre === activeGenre;
        const searchMatch = !query || (card.dataset.title ?? '').includes(query);

        let dayMatch = true;
        if (activeDay !== 'all') {
          const cardDay = card.dataset.updateDay;
          const cardHiatus = card.dataset.onHiatus === 'true';
          if (cardHiatus || cardDay === '') {
            dayMatch = false;
          } else if (activeDay === 'today') {
            dayMatch = parseInt(cardDay) === todayKST;
          } else {
            dayMatch = parseInt(cardDay) === parseInt(activeDay);
          }
        }

        return platformMatch && genreMatch && searchMatch && dayMatch;
      });

      // Second pass: trending — top 100 by anilist_score among visible
      let trendingSet = null;
      if (isTrending) {
        const scored = visible
          .filter(c => c.dataset.anilistScore)
          .sort((a, b) => parseFloat(b.dataset.anilistScore) - parseFloat(a.dataset.anilistScore))
          .slice(0, 100);
        trendingSet = new Set(scored);
      }

      allCards.forEach(card => {
        const inVisible = visible.includes(card);
        const inTrending = !isTrending || (trendingSet && trendingSet.has(card));
        card.style.display = (inVisible && inTrending) ? '' : 'none';
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.querySelector('.card-grid');
      const cards = [...grid.querySelectorAll(':scope > .card')];
      cards.sort((a, b) => {
        const dayA = a.dataset.onHiatus === 'true' || a.dataset.updateDay === '' ? null : parseInt(a.dataset.updateDay);
        const dayB = b.dataset.onHiatus === 'true' || b.dataset.updateDay === '' ? null : parseInt(b.dataset.updateDay);
        return getNextDropMs(dayA) - getNextDropMs(dayB);
      });
      cards.forEach(card => grid.appendChild(card));
      startCountdowns();

      // Day filter buttons
      document.querySelectorAll('.day-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          applyFilters();
        });
      });

      // Trending toggle
      const trendingBtn = document.getElementById('trending-toggle');
      trendingBtn?.addEventListener('click', () => {
        const isActive = trendingBtn.dataset.view === 'trending';
        trendingBtn.dataset.view = isActive ? 'all' : 'trending';
        trendingBtn.classList.toggle('active', !isActive);
        applyFilters();
      });
    });

    document.addEventListener('filterchange', applyFilters);
    document.getElementById('series-search')?.addEventListener('input', applyFilters);
  </script>
</Base>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.3px;
  }
  .logo-drop {
    font-family: 'Orbitron', sans-serif;
    color: var(--accent);
  }
  .logo-accent { color: var(--accent); }
  .header-nav { display: flex; gap: 16px; }
  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--muted); text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--accent); }

  /* Hero */
  .hero {
    padding: 56px 0 40px;
    text-align: center;
  }
  .hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-bottom: 16px;
    color: var(--text);
  }
  .hero-accent {
    font-family: 'Orbitron', sans-serif;
    color: var(--accent);
  }
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Search */
  .search-wrapper {
    position: relative;
    margin-bottom: 20px;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
    flex-shrink: 0;
  }
  #series-search {
    width: 100%;
    padding: 13px 16px 13px 46px;
    border-radius: 12px;
    border: 1.5px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 500;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
    -webkit-appearance: none;
  }
  #series-search::placeholder { color: var(--muted); opacity: 0.7; }
  #series-search:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.15);
  }
  #series-search::-webkit-search-cancel-button { cursor: pointer; }

  /* Day filter row */
  .day-filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 24px;
  }
  .day-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .day-btn {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    letter-spacing: 0.3px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .day-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .trending-btn {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    letter-spacing: 0.3px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .trending-btn.active {
    background: #ff6b35;
    border-color: #ff6b35;
    color: white;
  }

  /* Grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
    margin-bottom: 64px;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    font-family: 'Space Grotesk', sans-serif;
  }

  @media (max-width: 600px) {
    .hero { padding: 36px 0 28px; }
    .card-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
  }
</style>
