---
import StarButton from './StarButton.astro';
const { series } = Astro.props;
const DAYS = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
const platforms = series.platforms || [{
  platform: series.platform,
  label: series.platform_label,
  read_url: series.read_url,
}];
const platformKeys = platforms.map(p => p.platform);
---

<div
  class="card"
  data-genre={series.genre}
  data-platform={series.platform}
  data-platforms={JSON.stringify(platformKeys)}
  data-update-day={series.update_day ?? ''}
  data-on-hiatus={series.on_hiatus ? 'true' : 'false'}
  data-title={series.title.toLowerCase()}
  data-anilist-score={series.anilist_score ?? ''}
>
  <a href={`/${series.id}`} class="card-inner">
    <div class="card-cover">
      {series.cover_url && (
        <img
          src={series.cover_url}
          alt={`${series.title} cover`}
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
        />
      )}
      <div class="cover-placeholder" style={series.cover_url ? "display:none" : "display:flex"}>
        <span class="placeholder-title">{series.title.slice(0, 2).toUpperCase()}</span>
      </div>
      <div class="cover-overlay"></div>
      <div class="card-star">
        <StarButton id={series.id} title={series.title} size="sm" />
      </div>
      <span class="genre-pill">{series.genre}</span>
      {series.anilist_score && (
        <div class="score-badge" title="AniList score">★ {(series.anilist_score / 10).toFixed(1)}</div>
      )}
      <div class="platform-badges">
        {platforms.slice(0, 2).map(p => (
          <span class={`platform-badge platform-${p.platform}`}>{p.label}</span>
        ))}
        {platforms.length > 2 && (
          <span class="platform-badge platform-more">+{platforms.length - 2}</span>
        )}
      </div>
    </div>
    <div class="card-body">
      <div class="card-title">{series.title}</div>
      {series.update_day === null
        ? <span class="badge-tbd">Schedule TBD</span>
        : series.on_hiatus
          ? <span class="badge-hiatus">On Break</span>
          : (
            <>
              <div class="countdown" data-countdown-day={series.update_day}>--:--:--</div>
              <div class="countdown-units" data-countdown-units>D   H   M</div>
              <div class="card-day">{DAYS[series.update_day]}</div>
            </>
          )
      }
    </div>
  </a>
  <button
    class="notify-btn"
    data-series-id={series.id}
    aria-label={`Notify me when ${series.title} drops`}
  >🔔</button>
</div>

<script>
  import { subscribeToSeries, isSubscribed } from '../lib/notifications.js';

  document.querySelectorAll('.notify-btn').forEach(btn => {
    const id = btn.dataset.seriesId;
    if (isSubscribed(id)) btn.textContent = '🔔✓';

    btn.addEventListener('click', async e => {
      e.preventDefault();
      e.stopPropagation();
      const ok = await subscribeToSeries(id);
      if (ok) btn.textContent = '🔔✓';
    });
  });
</script>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    display: block;
    transition: border-color 0.2s;
    position: relative;
  }
  .card:has(.card-inner:active) { border-color: var(--accent); }

  .card-inner {
    display: block;
    text-decoration: none;
    color: var(--text);
  }

  .card-cover {
    aspect-ratio: 3/4;
    position: relative;
    overflow: hidden;
    background: var(--surface2);
  }
  .card-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 50%, var(--bg) 100%);
    opacity: 0.6;
  }
  .cover-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--accent) 0%, #a855f7 100%);
    align-items: center;
    justify-content: center;
    opacity: 0.4;
  }
  .placeholder-title {
    font-size: 2rem;
    font-weight: 900;
    color: white;
    opacity: 0.8;
    letter-spacing: 2px;
    font-family: 'Space Grotesk', sans-serif;
  }
  .card-star {
    position: absolute;
    top: 6px;
    left: 6px;
    z-index: 2;
  }
  .card-star :global(.star-btn) {
    background: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    color: white;
    opacity: 0.85;
    width: 32px;
    height: 32px;
  }
  .card-star :global(.star-btn .star-icon) {
    width: 18px;
    height: 18px;
    stroke-width: 1.8;
  }
  .card-star :global(.star-btn:hover) {
    opacity: 1;
    background: rgba(0, 0, 0, 0.7);
  }
  .card-star :global(.star-btn.bookmarked) {
    opacity: 1;
    background: rgba(0, 0, 0, 0.6);
  }

  .genre-pill {
    position: absolute; top: 10px; right: 10px;
    background: rgba(108,99,255,0.85);
    color: white;
    font-size: 10px; font-weight: 700;
    padding: 3px 8px; border-radius: 100px;
    letter-spacing: 0.5px;
    font-family: 'Space Grotesk', sans-serif;
  }
  .score-badge {
    position: absolute; bottom: 8px; right: 8px;
    background: rgba(0,0,0,0.75); color: #FFD700;
    font-size: 11px; font-weight: 700;
    padding: 3px 7px; border-radius: 6px;
    font-family: 'Space Grotesk', sans-serif;
  }

  .platform-badges {
    position: absolute; bottom: 10px; left: 10px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .platform-badge {
    display: inline-block;
    color: white;
    font-size: 9px; font-weight: 700;
    padding: 3px 7px; border-radius: 100px;
    letter-spacing: 0.5px;
    font-family: 'Space Grotesk', sans-serif;
    opacity: 0.9;
    width: fit-content;
  }
  .platform-webtoon   { background: #6C63FF; }
  .platform-tapas     { background: #F5821F; }
  .platform-mangaplus { background: #E40026; }
  .platform-tappytoon { background: #00C4B4; }
  .platform-manta     { background: #6c3de0; }
  .platform-more      { background: rgba(255,255,255,0.2); }

  .card-body { padding: 14px; }
  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 600;
    line-height: 1.3; margin-bottom: 12px;
    color: var(--text);
  }
  .countdown {
    font-family: 'Orbitron', sans-serif;
    font-size: 16px; font-weight: 600;
    letter-spacing: 2px; color: var(--text);
    margin-bottom: 4px;
  }
  .countdown-units {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 9px; color: var(--muted);
    letter-spacing: 4px; text-transform: uppercase;
    margin-bottom: 8px; padding-left: 2px;
  }
  .card-day {
    font-size: 11px; color: var(--accent);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600; letter-spacing: 0.5px;
  }
  .badge-hiatus, .badge-tbd {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    padding: 4px 10px; border-radius: 4px;
    border: 1px solid var(--border);
    font-family: 'Space Grotesk', sans-serif;
    display: inline-block;
  }
  .badge-hiatus { color: var(--hiatus); background: var(--tag-bg); }
  .badge-tbd    { color: var(--muted);  background: var(--surface2); }

  .notify-btn {
    position: absolute; bottom: 14px; right: 10px;
    background: none;
    border: none;
    font-size: 14px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    opacity: 0.6;
    transition: opacity 0.2s;
    z-index: 1;
  }
  .notify-btn:hover { opacity: 1; }
</style>
