---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SeriesCard from '../components/SeriesCard.astro';
import seriesData from '../data/series-data.json';
import { fetchManhwaCovers } from '../lib/anilist.js';

export async function getStaticPaths() {
  return seriesData.map(s => ({ params: { slug: s.id }, props: { series: s } }));
}

const { series } = Astro.props;

// Fetch cover + description for this series
const ids = series.anilist_id ? [series.anilist_id] : [];
const anilistData = ids.length ? await fetchManhwaCovers(ids) : [];
const anilist = anilistData[0] ?? null;
const cover = anilist?.coverImage?.large ?? null;
const description = anilist?.description ?? series.seo_description;

// "Also dropping this week" — same week as this series, different id, not on hiatus
const DAYS = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
const related = seriesData
  .filter(s => s.id !== series.id && !s.on_hiatus)
  .slice(0, 4)
  .map(s => ({ ...s, cover: null })); // covers omitted for related cards (build perf)

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${series.title} Next Episode Countdown`,
  "description": series.seo_description,
  "url": `https://webtoondrops.com/${series.id}`,
  "about": {
    "@type": "Book",
    "name": series.title,
    "genre": series.genre,
    "inLanguage": "ko"
  }
});
---

<Base
  title={`${series.title} Next Episode Countdown — WebtoonDrops`}
  description={series.seo_description}
  canonical={`https://webtoondrops.com/${series.id}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="logo">
        <span class="logo-drop">W</span>ebtoon<span class="logo-accent">Drops</span>
      </a>
      <ThemeToggle />
    </div>
  </header>

  <main class="container">
    <div class="series-hero">
      <div class="series-cover">
        {cover
          ? <img src={cover} alt={series.title} />
          : <div class="cover-fallback">{series.title}</div>
        }
        <div class="cover-glow"></div>
      </div>

      <div class="series-info">
        <div class="series-badges">
          <span class="badge-genre">{series.genre}</span>
          <span class={`badge-platform badge-${series.platform}`}>{series.platform_label}</span>
          {series.on_hiatus && <span class="badge-hiatus">On Break</span>}
          {series.update_day === null && !series.on_hiatus && <span class="badge-tbd">Schedule TBD</span>}
        </div>

        <h1>{series.title}</h1>

        {series.on_hiatus
          ? (
            <p class="hiatus-note">This series is currently on hiatus. Check back soon.</p>
          )
          : series.update_day === null
            ? (
              <p class="tbd-note">Release schedule not yet confirmed. Check back soon.</p>
            )
            : (
              <div class="countdown-block">
                <p class="drop-label">Next episode drops {DAYS[series.update_day]}</p>
                <div class="countdown-display" data-countdown-day={series.update_day}>--:--:--</div>
                <div class="countdown-units" data-countdown-units>D   H   M</div>
              </div>
            )
        }

        <div class="series-actions">
          <a href={series.read_url} class="btn-primary" target="_blank" rel="noopener noreferrer">
            Read on {series.platform_label} →
          </a>
          {series.amazon_vol1 && (
            <a href={series.amazon_vol1} class="btn-secondary" target="_blank" rel="noopener noreferrer">
              Buy Vol. 1 on Amazon
            </a>
          )}
        </div>

        {description && (
          <p class="series-desc">{description.replace(/<[^>]+>/g, '')}</p>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>Also dropping this week</h2>
        <div class="related-grid">
          {related.map(s => <SeriesCard series={s} />)}
        </div>
      </section>
    )}
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="/" class="back-link">← Back to all series</a>
      <span>WebtoonDrops — countdowns in KST (UTC+9)</span>
    </div>
  </footer>

  <script>
    import { startCountdowns } from '../scripts/countdown.js';
    document.addEventListener('DOMContentLoaded', startCountdowns);
  </script>
</Base>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    position: sticky; top: 0;
    background: var(--bg); z-index: 10;
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px; font-weight: 700; color: var(--text); letter-spacing: -0.3px;
  }
  .logo-drop { font-family: 'Orbitron', sans-serif; color: var(--accent); }
  .logo-accent { color: var(--accent); }

  /* Hero */
  .series-hero {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    padding: 48px 0;
    align-items: start;
  }
  .series-cover {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .series-cover img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .cover-fallback {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--surface2), var(--surface));
    display: flex; align-items: flex-end; padding: 16px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 600; color: var(--text);
  }
  .cover-glow {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 60%, var(--bg) 100%);
    opacity: 0.4;
  }

  /* Info */
  .series-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .badge-genre, .badge-platform, .badge-hiatus {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px; font-weight: 700; letter-spacing: 0.8px;
    padding: 4px 10px; border-radius: 100px; text-transform: uppercase;
  }
  .badge-genre { background: rgba(108,99,255,0.2); color: var(--accent); border: 1px solid var(--accent); }
  .badge-platform { color: white; }
  .badge-webtoon { background: #6C63FF; }
  .badge-tapas { background: #F5821F; }
  .badge-mangaplus { background: #E40026; }
  .badge-hiatus { background: var(--tag-bg); color: var(--hiatus); border: 1px solid var(--border); }
  .badge-tbd    { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

  .series-info h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(24px, 3vw, 42px);
    font-weight: 700; letter-spacing: -0.5px;
    line-height: 1.15; margin-bottom: 24px;
  }

  .drop-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; color: var(--muted); margin-bottom: 8px;
  }
  .countdown-display {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700; letter-spacing: 4px;
    color: var(--text); margin-bottom: 6px;
  }
  .countdown-units {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px; color: var(--muted);
    letter-spacing: 6px; text-transform: uppercase;
    margin-bottom: 28px;
  }
  .countdown-block { margin-bottom: 28px; }

  .tbd-note {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; color: var(--muted);
    margin-bottom: 28px;
    padding: 12px 16px;
    background: var(--surface2);
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .hiatus-note {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; color: var(--hiatus);
    margin-bottom: 28px;
    padding: 12px 16px;
    background: var(--tag-bg);
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .series-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
  .btn-primary, .btn-secondary {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 600;
    padding: 12px 24px; border-radius: 8px;
    text-decoration: none; display: inline-block;
  }
  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:active { opacity: 0.85; }
  .btn-secondary {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-secondary:active { border-color: var(--accent); }

  .series-desc {
    font-family: 'Inter', sans-serif;
    font-size: 14px; color: var(--muted);
    line-height: 1.7; max-width: 560px;
  }

  /* Related */
  .related { padding-bottom: 64px; }
  .related h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px; font-weight: 700;
    color: var(--text); margin-bottom: 20px;
    letter-spacing: -0.2px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 14px;
  }

  /* Footer */
  .site-footer { border-top: 1px solid var(--border); padding: 24px 0; }
  .footer-inner {
    display: flex; flex-wrap: wrap; gap: 12px;
    justify-content: space-between;
    font-size: 12px; color: var(--muted);
    font-family: 'Space Grotesk', sans-serif;
  }
  .back-link { color: var(--accent); }
  .back-link:active { opacity: 0.75; }

  @media (max-width: 640px) {
    .series-hero {
      grid-template-columns: 1fr;
    }
    .series-cover {
      max-width: 180px;
      margin: 0 auto;
    }
    .series-info h1 { text-align: center; }
    .series-badges { justify-content: center; }
    .drop-label { text-align: center; }
    .countdown-display { text-align: center; }
    .countdown-units { text-align: center; }
    .series-actions { justify-content: center; }
  }
</style>
