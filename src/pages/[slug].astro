---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SeriesCard from '../components/SeriesCard.astro';
import StarButton from '../components/StarButton.astro';
import seriesData from '../data/series-data.json';
import { fetchManhwaCovers } from '../lib/anilist.js';
import { getEpisodeHistory, formatHistoryDate } from '../lib/episode-history.js';

export async function getStaticPaths() {
  return seriesData.map(s => ({ params: { slug: s.id }, props: { series: s } }));
}

const { series } = Astro.props;

// Fetch description from AniList (cover is now stored in series.cover_url)
const ids = series.anilist_id ? [series.anilist_id] : [];
const anilistData = ids.length ? await fetchManhwaCovers(ids) : [];
const anilist = anilistData[0] ?? null;
const description = anilist?.description ?? series.seo_description;

const platforms = series.platforms || [{
  platform: series.platform,
  label: series.platform_label,
  read_url: series.read_url,
}];

// "Also dropping this week" — same week as this series, different id, not on hiatus
const DAYS = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
const related = seriesData
  .filter(s => s.id !== series.id && !s.on_hiatus)
  .slice(0, 4);

const history = getEpisodeHistory(series, 20);
const hasHistory = history.length > 0;
const primaryPlatform = platforms[0];

const RETAILER_FLAGS = {
  amazon_us: '🇺🇸',
  amazon_fr: '🇫🇷',
  amazon_uk: '🇬🇧',
  amazon_de: '🇩🇪',
  amazon_es: '🇪🇸',
  amazon_it: '🇮🇹',
};

// Only show buy section if at least one link is a direct /dp/ ASIN link (not a search URL)
const hasRealBuyLink = !!(series.buy_links?.some(l => l.url.includes('/dp/')));

const PLATFORM_LABELS: Record<string, string> = {
  webtoon: 'WEBTOON',
  tapas: 'Tapas',
  tappytoon: 'Tappytoon',
  mangaplus: 'MANGA Plus',
  lezhin: 'Lezhin',
};

const PLATFORM_COLORS: Record<string, string> = {
  webtoon: '#6650f5',
  tapas: '#e85d2f',
  tappytoon: '#00aaff',
  mangaplus: '#e40026',
  lezhin: '#d93f3f',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ComicSeries",
  "name": series.title,
  "alternateName": series.title_kr || undefined,
  "url": `https://webtoondrops.com/${series.id}`,
  "image": series.cover_url || undefined,
  "description": series.seo_description,
  "genre": series.genre,
  "inLanguage": "en",
  "countryOfOrigin": {
    "@type": "Country",
    "name": "South Korea"
  },
  "publisher": {
    "@type": "Organization",
    "name": primaryPlatform.label,
    "url": primaryPlatform.read_url
  },
  "numberOfEpisodes": series.total_episodes || undefined,
  "isAccessibleForFree": true,
  "publishingPrinciples": primaryPlatform.read_url,
  ...(series.reading_order && {
    "hasPart": series.reading_order.map((item, i) => ({
      "@type": "ComicStory",
      "name": item.label,
      "position": i + 1,
      "url": item.read_url
    }))
  })
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "WebtoonDrops", "item": "https://webtoondrops.com" },
    { "@type": "ListItem", "position": 2, "name": series.genre, "item": `https://webtoondrops.com/genre/${series.genre?.toLowerCase().replace(/\s+/g, '-')}` },
    { "@type": "ListItem", "position": 3, "name": series.title, "item": `https://webtoondrops.com/${series.id}` }
  ]
};
---

<Base
  title={`${series.title} Next Episode Countdown — WebtoonDrops`}
  description={series.seo_description}
  canonical={`https://webtoondrops.com/${series.id}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="logo">
        <span class="logo-drop">W</span>ebtoon<span class="logo-accent">Drops</span>
      </a>
      <nav class="header-nav">
        <a href="/just-dropped" class="nav-link">Today</a>
        <a href="/this-week" class="nav-link">This Week</a>
        <a href="/genre" class="nav-link">Genres</a>
        <a href="/my-schedule" class="nav-link">My Schedule</a>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main class="container">
    <div class="series-hero">
      <div class="series-cover">
        {series.cover_url
          ? <img src={series.cover_url} alt={series.title} />
          : <div class="cover-fallback">{series.title}</div>
        }
        <div class="cover-glow"></div>
      </div>

      <div class="series-info">
        <div class="series-badges">
          <a href={`/genre/${series.genre?.toLowerCase().replace(/\s+/g, '-')}`} class="badge-genre genre-tag">
            {series.genre}
          </a>
          {platforms.map(p => (
            <span class={`badge-platform badge-${p.platform}`}>{p.label}</span>
          ))}
          {series.on_hiatus && <span class="badge-hiatus">On Break</span>}
          {series.update_day === null && !series.on_hiatus && <span class="badge-tbd">Schedule TBD</span>}
        </div>

        <div class="title-row">
          <h1>{series.title}</h1>
          <StarButton id={series.id} title={series.title} size="md" />
        </div>

        {series.on_hiatus
          ? (
            <p class="hiatus-note">This series is currently on hiatus. Check back soon.</p>
          )
          : series.update_day === null
            ? (
              <p class="tbd-note">Release schedule not yet confirmed. Check back soon.</p>
            )
            : (
              <div class="countdown-block">
                <p class="drop-label">Next episode drops {DAYS[series.update_day]}</p>
                <div class="countdown-display" data-countdown-day={series.update_day}>--:--:--</div>
                <div class="countdown-units" data-countdown-units>D   H   M</div>
              </div>
            )
        }

        <div class="series-actions">
          {platforms.map(p => (
            <a
              href={p.read_url}
              target="_blank"
              rel="noopener"
              class="read-btn"
              style={`background: ${PLATFORM_COLORS[p.platform] ?? '#6650f5'}`}
            >
              Read on {PLATFORM_LABELS[p.platform] ?? p.label} →
            </a>
          ))}
          {hasRealBuyLink && (
            <section class="buy-section">
              <h3 class="buy-heading">📚 Own the Series</h3>
              <div
                class="buy-links"
                id={`buy-links-${series.id}`}
                data-buy-links={JSON.stringify(series.buy_links)}
              >
                {series.buy_links.map((link, i) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener sponsored"
                    class={`buy-btn retailer-${link.retailer}${i > 0 ? ' buy-btn-secondary' : ''}`}
                    data-countries={JSON.stringify(link.countries)}
                  >
                    <span class="buy-flag">{RETAILER_FLAGS[link.retailer] || '🛒'}</span>
                    {link.label}
                  </a>
                ))}
              </div>
              <p class="buy-note">Vol. 1 · Affiliate links help support WebtoonDrops</p>
            </section>
          )}
        </div>

        {series.update_day_name && !series.on_hiatus && (
          <p class="schedule-link">
            See all series dropping on <a href={`/this-week#${series.update_day_name.toLowerCase()}`}>
              {series.update_day_name}s this week →
            </a>
          </p>
        )}

        {description && (
          <p class="series-desc">{description.replace(/<[^>]+>/g, '')}</p>
        )}
      </div>
    </div>

    {hasHistory && (
      <section class="episode-history" id="episode-history">
        <details>
          <summary class="history-toggle">
            <span>📅 Episode Release History</span>
            <span class="history-toggle-icon">▾</span>
          </summary>

          <div class="history-list">
            {history.map(item => item.type === 'hiatus' ? (
              <div class="history-hiatus">
                <span class="hiatus-icon">⏸</span>
                <span class="hiatus-label">
                  Hiatus — {item.start} to {item.end}
                  {item.reason && <span class="hiatus-reason"> · {item.reason}</span>}
                </span>
              </div>
            ) : (
              <div class="history-episode">
                <span class="episode-label">
                  {item.episodeNumber ? `Ep ${item.episodeNumber}` : 'Episode'}
                </span>
                <span class="episode-date">{formatHistoryDate(item.date)}</span>
              </div>
            ))}
          </div>

          <p class="history-note">
            Dates are calculated from the series' weekly schedule and may vary slightly
            from actual release dates due to holidays or unannounced breaks.
          </p>
        </details>
      </section>
    )}

    {series.reading_order && series.reading_order.length > 1 && (
      <section class="reading-order">
        <h2>📖 Reading Order</h2>
        <div class="reading-order-list">
          {series.reading_order.map((item, i) => (
            <div class="reading-order-item">
              <div class="reading-order-number">{i + 1}</div>
              <div class="reading-order-info">
                <a href={item.read_url} target="_blank" rel="noopener" class="reading-order-label">
                  {item.label}
                </a>
                <span class="reading-order-chapters">{item.chapters}</span>
                {item.note && <span class="reading-order-note">{item.note}</span>}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="seo-content">
      <h2>{series.title} Release Schedule</h2>
      <p>
        {series.update_day !== null
          ? `${series.title} releases new episodes every ${series.update_day_name} on ${primaryPlatform.label}.`
          : `${series.title} releases on ${primaryPlatform.label}.`
        }
        {' '}
        {series.on_hiatus
          ? `The series is currently on hiatus. Check back for updates on when ${series.title} will resume.`
          : `Use the live countdown above to see exactly how long until the next ${series.title} episode drops.`
        }
        {series.total_episodes
          ? ` The series has released ${series.total_episodes} episodes to date.`
          : ''
        }
      </p>
      <p>
        Bookmark this page to always know when {series.title} updates.
        You can also click the 🔔 button to get a browser notification 1 hour before each new episode drops — no account required.
      </p>
      {series.update_day !== null && !series.on_hiatus && (
        <p class="schedule-link">
          See all series dropping on <a href={`/this-week#${series.update_day_name?.toLowerCase()}`}>
            {series.update_day_name}s this week →
          </a>
        </p>
      )}
    </section>

    {related.length > 0 && (
      <section class="related">
        <h2>Also dropping this week</h2>
        <div class="related-grid">
          {related.map(s => <SeriesCard series={s} />)}
        </div>
      </section>
    )}
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="/" class="back-link">← Back to all series</a>
      <span>WebtoonDrops — countdowns in KST (UTC+9)</span>
    </div>
  </footer>

  <script>
    import { startCountdowns } from '../scripts/countdown.js';
    import { detectCountry, sortBuyLinks } from '../scripts/geo.js';

    function initBuyButtons() {
      const containers = document.querySelectorAll('[id^="buy-links-"]');

      containers.forEach(container => {
        const raw = container.dataset.buyLinks;
        if (!raw) return;

        let buyLinks;
        try { buyLinks = JSON.parse(raw); } catch { return; }

        const country = detectCountry();
        const sorted = sortBuyLinks(buyLinks, country);
        if (sorted.length === 0) return;

        const buttons = Array.from(container.querySelectorAll('.buy-btn'));

        // Match button to sorted link by countries array identity
        const getBtn = (link) => buttons.find(btn => {
          try {
            const c = JSON.parse(btn.dataset.countries || '[]');
            return c.join(',') === (link.countries || []).join(',');
          } catch { return false; }
        });

        // Reorder: remove all, re-append sorted
        buttons.forEach(btn => btn.remove());
        sorted.forEach((link, i) => {
          const btn = getBtn(link);
          if (!btn) return;
          if (i === 0) {
            btn.classList.remove('buy-btn-secondary');
          } else {
            btn.classList.add('buy-btn-secondary');
          }
          container.appendChild(btn);
        });

        // Add "Show other stores" toggle
        const secondaryCount = sorted.length - 1;
        if (secondaryCount > 0) {
          const toggle = document.createElement('button');
          toggle.className = 'buy-toggle';
          toggle.textContent = `Show ${secondaryCount} other store${secondaryCount > 1 ? 's' : ''} →`;
          toggle.addEventListener('click', () => {
            const expanded = toggle.dataset.expanded === 'true';
            container.querySelectorAll('.buy-btn-secondary').forEach(
              btn => btn.classList.toggle('visible', !expanded)
            );
            toggle.textContent = expanded
              ? `Show ${secondaryCount} other store${secondaryCount > 1 ? 's' : ''} →`
              : 'Show fewer stores ↑';
            toggle.dataset.expanded = String(!expanded);
          });
          container.after(toggle);
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      startCountdowns();
      initBuyButtons();
    });
  </script>
</Base>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    position: sticky; top: 0;
    background: var(--bg); z-index: 10;
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px; font-weight: 700; color: var(--text); letter-spacing: -0.3px;
  }
  .logo-drop { font-family: 'Orbitron', sans-serif; color: var(--accent); }
  .logo-accent { color: var(--accent); }
  .header-nav { display: flex; gap: 16px; flex: 1; justify-content: center; }
  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--muted); text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--accent); }

  /* Hero */
  .series-hero {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    padding: 48px 0;
    align-items: start;
  }
  .series-cover {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .series-cover img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .cover-fallback {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--surface2), var(--surface));
    display: flex; align-items: flex-end; padding: 16px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 600; color: var(--text);
  }
  .cover-glow {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 60%, var(--bg) 100%);
    opacity: 0.4;
  }

  /* Info */
  .series-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .genre-tag { text-decoration: none; }
  .genre-tag:hover { opacity: 0.8; }
  .badge-genre, .badge-platform, .badge-hiatus {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px; font-weight: 700; letter-spacing: 0.8px;
    padding: 4px 10px; border-radius: 100px; text-transform: uppercase;
  }
  .badge-genre { background: rgba(108,99,255,0.2); color: var(--accent); border: 1px solid var(--accent); }
  .badge-platform { color: white; }
  .badge-webtoon   { background: #6C63FF; }
  .badge-tapas     { background: #F5821F; }
  .badge-mangaplus { background: #E40026; }
  .badge-tappytoon { background: #00C4B4; }
  .badge-lezhin    { background: #d93f3f; }
  .badge-hiatus { background: var(--tag-bg); color: var(--hiatus); border: 1px solid var(--border); }
  .badge-tbd    { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

  .title-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 24px;
  }
  .title-row h1 {
    flex: 1;
  }
  .series-info h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(24px, 3vw, 42px);
    font-weight: 700; letter-spacing: -0.5px;
    line-height: 1.15; margin-bottom: 0;
  }

  .drop-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; color: var(--muted); margin-bottom: 8px;
  }
  .countdown-display {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700; letter-spacing: 4px;
    color: var(--text); margin-bottom: 6px;
  }
  .countdown-units {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px; color: var(--muted);
    letter-spacing: 6px; text-transform: uppercase;
    margin-bottom: 28px;
  }
  .countdown-block { margin-bottom: 28px; }

  .tbd-note {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; color: var(--muted);
    margin-bottom: 28px;
    padding: 12px 16px;
    background: var(--surface2);
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .hiatus-note {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; color: var(--hiatus);
    margin-bottom: 28px;
    padding: 12px 16px;
    background: var(--tag-bg);
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .series-actions { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; max-width: 380px; }
  .read-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    border-radius: 10px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    color: white;
    transition: opacity 0.15s;
  }
  .read-btn:hover { opacity: 0.85; }

  .schedule-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; color: var(--muted);
    margin-bottom: 16px;
  }
  .schedule-link a { color: var(--accent); text-decoration: none; }
  .schedule-link a:hover { text-decoration: underline; }

  .series-desc {
    font-family: 'Inter', sans-serif;
    font-size: 14px; color: var(--muted);
    line-height: 1.7; max-width: 560px;
  }

  /* Episode History */
  .episode-history {
    margin-top: 2rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .history-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    cursor: pointer;
    font-weight: 600;
    font-size: 15px;
    list-style: none;
    background: var(--surface);
    transition: background 0.15s;
    font-family: 'Space Grotesk', sans-serif;
  }
  .history-toggle::-webkit-details-marker { display: none; }
  .history-toggle:hover { background: var(--surface2); }
  details[open] .history-toggle-icon { transform: rotate(180deg); }
  .history-toggle-icon { transition: transform 0.2s; }
  .history-list { border-top: 1px solid var(--border); }
  .history-episode {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .history-episode:last-child { border-bottom: none; }
  .episode-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    color: var(--accent);
    min-width: 80px;
  }
  .episode-date { color: var(--muted); font-family: 'Inter', sans-serif; }
  .history-hiatus {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: rgba(255, 165, 0, 0.08);
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    color: #F5821F;
    font-family: 'Space Grotesk', sans-serif;
  }
  .hiatus-reason { opacity: 0.7; }
  .history-note {
    padding: 12px 20px;
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
    border-top: 1px solid var(--border);
    margin: 0;
    font-family: 'Inter', sans-serif;
  }

  /* Buy section */
  .buy-section {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .buy-heading {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
    font-family: 'Space Grotesk', sans-serif;
  }
  .buy-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .buy-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    background: #FF9900;
    color: #111;
    transition: opacity 0.15s, transform 0.1s;
    font-family: 'Space Grotesk', sans-serif;
  }
  .buy-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .buy-btn:active { transform: translateY(0); }
  /* Secondary buttons hidden until JS shows them or toggled */
  .buy-btn-secondary { display: none; font-size: 13px; padding: 9px 14px; opacity: 0.85; }
  .buy-btn-secondary.visible { display: flex; }
  .buy-flag { font-size: 18px; }
  .buy-toggle {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 12px;
    cursor: pointer;
    padding: 6px 0 0;
    text-decoration: underline;
    text-align: left;
    font-family: 'Inter', sans-serif;
  }
  .buy-note {
    font-size: 11px;
    color: var(--muted);
    margin: 8px 0 0;
    opacity: 0.6;
    font-family: 'Inter', sans-serif;
  }

  /* Reading Order */
  .reading-order {
    margin-top: 2rem; margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .reading-order h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem;
    color: var(--text);
