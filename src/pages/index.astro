---
import Base from '../layouts/Base.astro';
import SeriesCard from '../components/SeriesCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import GenreFilter from '../components/GenreFilter.astro';
import LiveBanner from '../components/LiveBanner.astro';
import seriesData from '../data/series-data.json';
import { fetchManhwaCovers } from '../lib/anilist.js';

const ids = seriesData.filter(s => s.anilist_id).map(s => s.anilist_id);
const anilistData = await fetchManhwaCovers(ids);
const anilistMap = Object.fromEntries(anilistData.map(m => [m.id, m]));

function getNextDropDays(s) {
  if (s.on_hiatus || s.update_day == null) return Infinity;
  const nowKST = new Date(Date.now() + 9 * 60 * 60 * 1000);
  const currentDayKST = nowKST.getUTCDay();
  let daysAhead = (s.update_day - currentDayKST + 7) % 7;
  if (daysAhead === 0) daysAhead = 7;
  return daysAhead;
}

const series = seriesData
  .map(s => ({
    ...s,
    cover: s.anilist_id ? (anilistMap[s.anilist_id]?.coverImage?.large ?? null) : null,
  }))
  .sort((a, b) => getNextDropDays(a) - getNextDropDays(b));

const genres = [...new Set(seriesData.map(s => s.genre))].sort();
const platforms = [
  { value: 'webtoon',   label: 'WEBTOON' },
  { value: 'tapas',     label: 'TAPAS' },
  { value: 'mangaplus', label: 'MANGA PLUS' },
  { value: 'tappytoon', label: 'TAPPYTOON' },
];
---

<Base>
  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="logo">
        <span class="logo-drop">W</span>ebtoon<span class="logo-accent">Drops</span>
      </a>
      <nav class="header-nav">
        <a href="/just-dropped" class="nav-link">Today</a>
        <a href="/this-week" class="nav-link">This Week</a>
        <a href="/genre" class="nav-link">Genres</a>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <h1>countdown to your<br /><span class="hero-accent">next episode drop</span></h1>
      <p class="hero-sub">Live release timers for every major WEBTOON, Tapas, and MANGA Plus series. No spoilers. Pure utility.</p>
    </section>

    <LiveBanner series={seriesData} />
    <GenreFilter genres={genres} platforms={platforms} />

    <div class="card-grid">
      {series.map(s => <SeriesCard series={s} />)}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>WebtoonDrops — all countdowns in KST (UTC+9)</span>
      <span>Not affiliated with WEBTOON, Tapas, or MANGA Plus</span>
    </div>
  </footer>

  <script>
    import { startCountdowns } from '../scripts/countdown.js';

    const KST_OFFSET_MS = 9 * 60 * 60 * 1000;

    function getNextDropMs(updateDay) {
      if (updateDay === null) return Infinity;
      const nowKST = new Date(Date.now() + KST_OFFSET_MS);
      const currentDayKST = nowKST.getUTCDay();
      let daysAhead = (updateDay - currentDayKST + 7) % 7;
      if (daysAhead === 0) daysAhead = 7;
      return daysAhead * 24 * 60 * 60 * 1000;
    }

    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.querySelector('.card-grid');
      const cards = [...grid.querySelectorAll(':scope > .card')];
      cards.sort((a, b) => {
        const dayA = a.dataset.onHiatus === 'true' || a.dataset.updateDay === ''
          ? null : parseInt(a.dataset.updateDay);
        const dayB = b.dataset.onHiatus === 'true' || b.dataset.updateDay === ''
          ? null : parseInt(b.dataset.updateDay);
        return getNextDropMs(dayA) - getNextDropMs(dayB);
      });
      cards.forEach(card => grid.appendChild(card));
      startCountdowns();
    });
  </script>
</Base>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header */
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.3px;
  }
  .logo-drop {
    font-family: 'Orbitron', sans-serif;
    color: var(--accent);
  }
  .logo-accent { color: var(--accent); }
  .header-nav { display: flex; gap: 16px; }
  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--muted); text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--accent); }

  /* Hero */
  .hero {
    padding: 56px 0 40px;
    text-align: center;
  }
  .hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-bottom: 16px;
    color: var(--text);
  }
  .hero-accent {
    font-family: 'Orbitron', sans-serif;
    color: var(--accent);
  }
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
    margin-bottom: 64px;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    font-family: 'Space Grotesk', sans-serif;
  }

  @media (max-width: 600px) {
    .hero { padding: 36px 0 28px; }
    .card-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
  }
</style>
